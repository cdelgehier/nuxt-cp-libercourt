# =============================================================================
# Netlify DB (Neon PostgreSQL) — injecté automatiquement par Netlify
# Pour le dev local : récupérer depuis le dashboard Netlify > Site > DB
# =============================================================================
NETLIFY_DATABASE_URL=postgresql://...
NETLIFY_DATABASE_URL_UNPOOLED=postgresql://...

# =============================================================================
# SmartPing FFTT
# =============================================================================
SMARTPING_APP_CODE=SX020
SMARTPING_PASSWORD=
SMARTPING_EMAIL=

# =============================================================================
# Authentik OIDC
# =============================================================================
NUXT_OIDC_ISSUER=https://auth.jackruby.qzz.io/application/o/libercourt-cp/
NUXT_OIDC_AUTHORIZATION_URL=https://auth.jackruby.qzz.io/application/o/authorize/
NUXT_OIDC_TOKEN_URL=https://auth.jackruby.qzz.io/application/o/token/
NUXT_OIDC_USERINFO_URL=https://auth.jackruby.qzz.io/application/o/userinfo/
NUXT_OIDC_CLIENT_ID=
NUXT_OIDC_CLIENT_SECRET=

# =============================================================================
# Sessions nuxt-oidc-auth (générer avec : node -e "require('crypto').randomBytes(48).toString('base64url') |> console.log")
# =============================================================================
NUXT_OIDC_SESSION_SECRET=
NUXT_OIDC_TOKEN_KEY=
NUXT_OIDC_AUTH_SESSION_SECRET=

# =============================================================================
# Admin Basic Auth fallback (si Authentik injoignable)
# Générer le hash : htpasswd -bnBC 12 "" mot_de_passe | tr -d ':\n'
# =============================================================================
ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_HASH=  # bcrypt hash — générer avec : node -e "require('bcryptjs').hash('monmdp', 12).then(console.log)"
SESSION_SECRET=         # chaîne aléatoire longue (min 32 chars) pour signer les cookies de session

# =============================================================================
# ID FFTT du club (exposé côté client)
# =============================================================================
CLUB_FFTT_ID=07620112

# =============================================================================
# Optionnels — news
# =============================================================================
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
