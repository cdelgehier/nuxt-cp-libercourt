{
  "name": "club-pongiste-libercourtois",
  "version": "1.7.0",
  "description": "Site vitrine du Club Pongiste Libercourtois",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.12.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "rm -rf .nuxt/cache && nuxt dev",
    "dev:open": "rm -rf .nuxt/cache && nuxt dev --open",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"**/*.{vue,js,ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{vue,js,ts,json,md}\"",
    "typecheck": "vue-tsc --noEmit",
    "style:lint": "stylelint \"**/*.{css,scss,vue}\" --fix",
    "style:check": "stylelint \"**/*.{css,scss,vue}\"",
    "quality:check": "pnpm lint:check && pnpm format:check && pnpm typecheck && pnpm style:check",
    "quality:fix": "pnpm lint && pnpm format && pnpm style:lint",
    "precommit:setup": "./setup-precommit.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/db/seed.ts",
    "db:seed-series": "tsx server/db/seed-series.ts",
    "db:reset": "tsx server/db/reset.ts && tsx server/db/seed.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.46",
    "@nuxt/devtools": "latest",
    "@nuxt/eslint-config": "^0.3.13",
    "@playwright/test": "^1.59.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "nuxt": "^4.4.2",
    "pg": "^8.20.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "vue-tsc": "^2.0.21"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@netlify/functions": "^5.1.5",
    "@netlify/neon": "^0.1.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.6.0",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/nuxt": "^13.9.0",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "fast-xml-parser": "^5.2.5",
    "googleapis": "^150.0.1",
    "jsdom": "^26.1.0",
    "nuxt-oidc-auth": "1.0.0-beta.10",
    "pinia": "^3.0.4",
    "vee-validate": "^4.15.1",
    "vue-chartjs": "^5.3.2",
    "zod": "^4.0.0"
  },
  "keywords": [
    "ping-pong",
    "tennis-de-table",
    "club-sportif",
    "nuxt",
    "vue",
    "libercourtois"
  ],
  "author": "Club Pongiste Libercourtois",
  "license": "MIT"
}
